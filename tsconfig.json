{
	"extends": "@vue/tsconfig/tsconfig.json",
	"include": [
		"src/**/*.ts",
		"src/**/*.vue",
		"tests/**/*.ts",
		"vite.config.ts",
		"vitest.config.ts",
		"playwright.config.ts"
	],
	"compilerOptions": {
		"lib": [
			"DOM",
			"ES2022"
		],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"noImplicitAny": true,
		"strict": true,
		"types": [
			"node",
			"vitest/globals"
		]
	},
	"vueCompilerOptions": {
		"target": 2.7
	}
}
