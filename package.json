{
	"name": "files_vrmviewer",
	"version": "0.1.1",
	"description": "VRM file viewer for Nextcloud",
	"license": "AGPL-3.0-or-later",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite --mode production build",
		"dev": "vite --mode development build",
		"watch": "vite --mode development build --watch",
		"typecheck": "vue-tsc --noEmit",
		"lint": "eslint src --ext .ts,.vue && if [ -d tests ]; then eslint tests --ext .ts; fi",
		"lint:fix": "eslint src --ext .ts,.vue --fix && if [ -d tests ]; then eslint tests --ext .ts --fix; fi",
		"stylelint": "stylelint 'src/**/*.{vue,css,scss}'",
		"stylelint:fix": "stylelint 'src/**/*.{vue,css,scss}' --fix",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"fixtures:download": "bash tests/e2e/download-fixtures.sh",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down -v",
		"docker:setup": "bash tests/e2e/setup-nextcloud.sh",
		"package": "bash scripts/package.sh"
	},
	"browserslist": [
		"extends @nextcloud/browserslist-config"
	],
	"engines": {
		"node": "^24.0.0",
		"npm": "^11.3.0"
	},
	"dependencies": {
		"@mdi/svg": "7.4.47",
		"@nextcloud/files": "4.0.0",
		"@nextcloud/l10n": "3.4.1",
		"@nextcloud/viewer": "1.0.0",
		"@nextcloud/vue": "8.37.0",
		"@pixiv/three-vrm": "3.5.4",
		"three": "0.184.0",
		"vue": "2.7.16"
	},
	"devDependencies": {
		"@nextcloud/browserslist-config": "3.0.1",
		"@nextcloud/eslint-config": "8.4.2",
		"@nextcloud/stylelint-config": "3.2.2",
		"@nextcloud/vite-config": "1.5.6",
		"@playwright/test": "1.61.0",
		"@types/node": "24.3.0",
		"@types/three": "0.184.1",
		"@vitejs/plugin-vue2": "2.3.4",
		"@vue/test-utils": "1.3.6",
		"@vue/tsconfig": "0.5.1",
		"happy-dom": "18.0.1",
		"typescript": "5.9.3",
		"vite": "6.4.3",
		"vitest": "3.2.4",
		"vue-template-compiler": "2.7.16",
		"vue-tsc": "2.2.12"
	}
}
